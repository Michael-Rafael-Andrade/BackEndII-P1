{{> navbar }}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5 class="card-title mb-4">Produtos Cadastrados</h5>
            
            {{#if produtos.length}}
                <table class="table table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Categoria</th>
                            <th>Nome</th>
                            <th>Qtd.</th>
                            <th>Preço</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each produtos}}
                        <tr>
                            <td>{{this.categoria.nome}}</td>
                            <td>{{this.nome}}</td>
                            <td>{{this.quantidade}}</td>
                            <td>R$ {{this.preco}}</td>
                            <td>
                                <a href="/produtos/{{this.id}}" class="btn btn-secondary btn-sm text-white me-1">
                                    <i class="bi bi-eye"></i> Consultar
                                </a>

                                {{#if (eq ../user.perfil 'lojista')}}
                                    
                                    {{#if this.quantidade}}
                                        <form action="/produtos/venda/{{this.id}}" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-danger btn-sm text-white me-1">
                                                <i class="bi bi-cart-dash"></i> Registrar Venda
                                            </button>
                                        </form>
                                    {{/if}}
                                    
                                    <form action="/produtos/compra/{{this.id}}" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-success btn-sm text-white">
                                            <i class="bi bi-cart-plus"></i> Registrar Compra
                                        </button>
                                    </form>

                                {{/if}}
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            {{else}}
                <p class="text-muted">Nenhum produto cadastrado no momento.</p>
            {{/if}}
        </div>
    </div>
</div>