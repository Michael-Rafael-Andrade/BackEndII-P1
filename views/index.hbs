{{> navbar }}

<h1 class="mb-4">{{titulo_pagina}}</h1>

<div class="card mb-4">
    <div class="card-header bg-light">
        <strong>Filtro por Categoria</strong>
    </div>
    <div class="card-body">
        <a href="/" class="btn btn-outline-secondary me-2 mb-2">Todas</a>

        {{#each categorias}}
        <a href="/?categoria={{id}}" class="btn btn-outline-primary me-2 mb-2">{{nome}}</a>
        {{/each}}
    </div>
</div>

<div class="card">
    <div class="card-body">
        {{#if produtos}}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Preço (R$)</th>
                        <th>Categoria</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each produtos}}
                    <tr>
                        <td>{{id}}</td>
                        <td>{{nome}}</td>
                        <td>{{preco}}</td>
                        <td>{{categoria.nome}}</td> 
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <div class="alert alert-warning mb-0">Nenhum produto encontrado.</div>
        {{/if}}
    </div>
</div>