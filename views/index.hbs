{{> navbar }}

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Produtos Cadastrados</h5>
        
        {{#if produtos}}
        <div class="table-responsive" style="min-height: 60vh;">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nome</th>
                        <th>Preço (R$)</th>
                        <th>Quantidade</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each produtos}}
                    <tr>
                        <td>{{id}}</td>
                        <td>{{nome}}</td>
                        <td>{{preco}}</td>
                        <td>{{quantidade}}</td>
                        <td>{{status}}</td>
                        <td>
                            <a href="/produtos/consulta/{{id}}" class="btn btn-sm btn-secondary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{else}}
        <p class="text-muted">Nenhum produto cadastrado.</p>
        {{/if}}
    </div>
</div>