{{> navbar }}
<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h3 class="card-title text-primary mb-3">{{produto.nome}}</h3>
                <h6 class="text-muted mb-4">Categoria: <span class="badge bg-secondary">{{produto.categoria.nome}}</span></h6>
                
                <hr>
                <p class="mt-3"><strong>Descrição:</strong></p>
                <p class="text-secondary">{{produto.descricao}}</p>
                
                <div class="row mt-4 bg-light p-3 rounded">
                    <div class="col-sm-4">
                        <p class="mb-1 text-muted">Preço</p>
                        <h5>R$ {{produto.preco}}</h5>
                    </div>
                    <div class="col-sm-4">
                        <p class="mb-1 text-muted">Estoque Disponível</p>
                        <h5>{{produto.quantidade}} unid.</h5>
                    </div>
                    <div class="col-sm-4">
                        <p class="mb-1 text-muted">Status do Sistema</p>
                        <h5><span class="badge {{#if (eq produto.status 'ativo')}}bg-success{{else}}bg-danger{{/if}}">{{produto.status}}</span></h5>
                    </div>
                </div>

                <div class="mt-4">
                    <a href="/" class="btn btn-primary">
                        <i class="bi bi-arrow-left"></i> Voltar para a Página Principal
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>